      "name": "Entity Extraction LLM",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "position": [
        160,
        -336
      ],
      "typeVersion": 1.9
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nreturn items.map(item => {\n  let raw = item.json.output || item.json.response || item.json.text || \"\";\n  if (typeof raw === \"object\" && raw !== null) {\n    return { json: raw };\n  }\n  raw = String(raw).replace(/```[\\s\\S]*?```/g, \"\").trim();\n  try {\n    const parsed = JSON.parse(raw);\n    if (parsed.entities || parsed.relationships) {\n      return { json: { entities: parsed.entities || [], relationships: parsed.relationships || [] } };\n    }\n  } catch(e) {\n    return { json: { error: \"Parse failed: \" + raw.substring(0, 100), entities: [], relationships: [] } };\n  }\n  return { json: { entities: [], relationships: [] } };\n});"
      },
