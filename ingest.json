        "messages": {
          "messageValues": [
            {
              "message": "You are an entity and relationship extraction system. Extract all named entities (people, organizations, concepts, technologies, locations) and the relationships between them from the text below.\n\nRespond with ONLY valid JSON in this exact format, no other text:\n{\"entities\": [{\"name\": \"...\", \"type\": \"Person|Organization|Concept|Technology|Location\", \"properties\": {}}], \"relationships\": [{\"source\": \"...\", \"target\": \"...\", \"type\": \"RELATED_TO\"}]}"
            }
