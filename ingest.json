      "typeVersion": 1
    },
    {
      "parameters": {
        "jsCode": "// Text splitter: splits text into chunks of ~1000 chars with 200 overlap\nconst items = $input.all();\nconst chunks = [];\nconst chunkSize = 5000;\nconst chunkOverlap = 200;\n\nfor (const item of items) {\n  let text = item.json.text || item.json.data || item.json.content || JSON.stringify(item.json);\n  if (typeof text !== 'string') text = String(text);\n  if (!text) continue;\n  const source = item.json.fileName || item.json.source || 'unknown';\n  let start = 0;\n  let idx = 0;\n  while (start < text.length) {\n    const end = Math.min(start + chunkSize, text.length);\n    const chunk = text.substring(start, end);\n    if (chunk.trim()) {\n      chunks.push({ json: { text: chunk, chunkIndex: idx, source: source } });\n      idx++;\n    }\n    start += chunkSize - chunkOverlap;\n    if (start >= text.length) break;\n  }\n}\nreturn chunks.length ? chunks : items;"
      },
      "id": "28eb9a39-bdeb-4ec3-828e-32ff9191a7f0",
      "name": "Split Text",
      "type": "n8n-nodes-base.code",
      "position": [
        -64,
        -32
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst stmts = [];\nfor (const item of items) {\n  let out = item.json.output || item.json.response || item.json.text || item.json;\n  if (typeof out === \"string\") {\n    try { out = JSON.parse(out.replace(/```[\\\\s\\\\S]*?```/g, \"\").trim() || \"{}\"); }\n    catch(e) { stmts.push(\"// Parse error: \" + out.substring(0,80)); continue; }\n  }\n  const ents = out.entities || [];\n  const rels = out.relationships || [];\n  ents.forEach(e => {\n    const p = JSON.stringify(e.properties || {});\n    stmts.push(`MERGE (e:${e.type || \"Entity\"} {name: ${JSON.stringify(e.name)}}) SET e += ${p}`);\n  });\n  rels.forEach(r => {\n    stmts.push(`MATCH (a {name: ${JSON.stringify(r.source)}}), (b {name: ${JSON.stringify(r.target)}}) MERGE (a)-[:${r.type || \"RELATED_TO\"}]->(b)`);\n  });\n}\nif (stmts.length === 0) {\n  return [{ json: { cypher: \"RETURN 1\", index: 0, note: \"no entities found\" } }];\n}\nreturn stmts.map((s,i) => ({ json: { cypher: s, index: i } }));"
      },
